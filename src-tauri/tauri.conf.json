{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "charminal",
  "version": "0.5.1",
  "identifier": "dev.charminal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Charminal",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval' blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; media-src 'self' asset: https://asset.localhost http://asset.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost asset: https://asset.localhost blob:; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/.charminal/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhGNjVCQUEzMUUzMTQ1NTkKUldSWlJURWVvN3BsajJLdWRiVjYycmpacW1hSVNLUXUvYVpsNHpkcUh4MlJST3ZYZWR0WFdsQ08K",
      "endpoints": ["https://github.com/sktkkoo/Charminal/releases/latest/download/latest.json"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "entitlements": "Entitlements.plist"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/charminal-plugin/.claude-plugin/plugin.json",
      "resources/charminal-plugin/.codex-plugin/plugin.json",
      "resources/charminal-plugin/commands-en/*",
      "resources/charminal-plugin/commands-ja/*"
    ]
  }
}
