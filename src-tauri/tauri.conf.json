{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "charminal",
  "version": "0.0.1",
  "identifier": "dev.charminal.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "charminal",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost blob: data:; connect-src 'self' ipc: http://ipc.localhost; worker-src 'self' blob:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/.charminal/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/charminal-plugin/.claude-plugin/plugin.json",
      "resources/charminal-plugin/commands/charm.md"
    ]
  }
}
