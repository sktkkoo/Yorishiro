{
  "name": "charminal",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Charminal — someone who lives in your terminal. A Tauri desktop app pairing Claude Code with a 3D VRM character that shares your workspace.",
  "keywords": [
    "tauri",
    "react",
    "three",
    "vrm",
    "claude-code",
    "terminal",
    "desktop-app",
    "inhabited-interface"
  ],
  "author": "okktks <6031376+sktkkoo@users.noreply.github.com>",
  "license": "UNLICENSED",
  "scripts": {
    "fetch-assets": "node scripts/fetch-assets.mjs",
    "predev": "node scripts/fetch-assets.mjs",
    "prebuild": "node scripts/fetch-assets.mjs",
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:run": "vitest run --passWithNoTests",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "fmt": "biome check --write . && cargo fmt --manifest-path src-tauri/Cargo.toml",
    "fmt:check": "biome check . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check",
    "lint": "biome lint . && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "check": "biome check . && cargo fmt --manifest-path src-tauri/Cargo.toml -- --check && cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "doc": "typedoc",
    "doc:rust": "cargo doc --manifest-path src-tauri/Cargo.toml --no-deps --document-private-items",
    "doc:open": "open docs/api/typescript/index.html",
    "doc:rust:open": "open src-tauri/target/doc/charminal_lib/index.html",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.5.1",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^4.6.0",
    "lefthook": "^2.1.5",
    "typedoc": "^0.28.19",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.4"
  }
}
